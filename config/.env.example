# ySEO-PRO-AI Environment Variables
# Copy this to .env and fill in your values

# Google Search Console
GSC_CREDENTIALS_JSON=
GSC_PROPERTY_URL=https://ylink.pro

# IndexNow
INDEXNOW_KEY=your-indexnow-key-here
INDEXNOW_KEY_LOCATION=https://ylink.pro/your-key.txt

# Blog API (yLink.pro)
BLOG_API_URL=https://ylink.pro/blog-api.php
BLOG_API_TOKEN=your-bearer-token

# DataForSEO (optional)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Moz API (optional)
MOZ_ACCESS_ID=
MOZ_SECRET_KEY=

# OpenAI / Claude (for content generation)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
